{
    "name": "waaseyaa/media",
    "description": "Media entity type and file management for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../plugin"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../typed-data"
        },
        {
            "type": "path",
            "url": "../config"
        }
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/entity": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Media\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Media\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Media\\MediaServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
