{
    "name": "aurora/media",
    "description": "Media entity type and file management for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "aurora/entity": "^0.1",
        "aurora/field": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\Media\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\Media\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
